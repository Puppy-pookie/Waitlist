# Postgres connection string (Neon recommended — https://neon.tech)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# 32-byte hex key for AES-256-GCM email encryption.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Keep this secret. Losing it means existing encrypted emails become unrecoverable.
WAITLIST_ENCRYPTION_KEY=

# Google OAuth Client ID (from Google Cloud Console > APIs & Services > Credentials)
# Same value goes in public/config.js (safe to expose client-side) and here (used server-side to verify tokens)
GOOGLE_CLIENT_ID=
